{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist-electron",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "src/backend/**/*",
    "src/electron/**/*"
  ],
  "exclude": [
    "src/frontend/renderer/**/*",
    "src/backend/qeeclaw-core-sdk/src/**/*",
    "src/backend/qeeclaw-core-sdk/examples/**/*"
  ]
}
